<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="admin-header fade-up">
      <h1>📢 Управление рекламой</h1>
      <p class="text-secondary">Все заявки на рекламу и их статусы</p>
    </div>

    <section class="admin-section fade-up">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Проект</th>
            <th>Бюджет</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% requests.forEach(r => { %>
            <tr>
              <td><%= r.project_name %></td>
              <td><%= r.budget_tokens %></td>
              <td><%= r.status %></td>
              <td>
                <div class="admin-actions">
                  <% if (r.status === 'pending') { %>
                    <form action="/admin-ads/approve/<%= r.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm approve">✅ Одобрить</button>
                    </form>
                    <form action="/admin-ads/reject/<%= r.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm reject">❌ Отклонить</button>
                    </form>
                  <% } else if (r.status === 'active') { %>
                    <span style="color:var(--accent-green);">🟢 Активна (позиция <%= r.queue_position %>)</span>
                  <% } else { %>
                    <span style="color:var(--text-muted);">Завершена</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>