<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/notifications.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <!-- Баннер -->
    <div class="ad-slot ad-slot-top fade-up" style="--delay:0.1">
      <% if (activeBanners && activeBanners.length > 0) { %>
        <a href="<%= activeBanners[0].link || '#' %>" target="_blank" class="ad-banner">
          <img src="<%= activeBanners[0].banner %>" alt="<%= activeBanners[0].project_name %>">
          <span class="ad-label">Реклама</span>
        </a>
      <% } else { %>
        <div class="ad-placeholder">
          <span class="placeholder-icon">📢</span>
          <span class="placeholder-text">Рекламное место</span>
          <a href="/ad-buy" class="btn btn-sm btn-placeholder">Разместить</a>
        </div>
      <% } %>
    </div>

    <div class="mail-container fade-up" style="--delay:0.2">
      <!-- Левая панель -->
      <aside class="mail-sidebar">
        <div class="mail-card">
          <div class="card-title">📁 Папки</div>
          <button class="folder-item active" data-filter="all">
            <span class="icon">📬</span> Все письма
            <span class="badge"><%= notifications ? notifications.length : 0 %></span>
          </button>
          <button class="folder-item" data-filter="unread">
            <span class="icon">📩</span> Непрочитанные
            <span class="badge"><%= unreadCount || 0 %></span>
          </button>
          <button class="folder-item" data-filter="read">
            <span class="icon">📖</span> Прочитанные
          </button>
        </div>
        <div class="mail-card">
          <div class="card-title">🏷️ Фильтры</div>
          <button class="filter-item active" data-filter-type="all">Все</button>
          <button class="filter-item" data-filter-type="season">📅 Сезоны</button>
          <button class="filter-item" data-filter-type="balance">💰 Начисления</button>
          <button class="filter-item" data-filter-type="system">📩 Системные</button>
          <hr class="filter-divider">
          <div class="filter-total">Всего: <strong id="totalCount"><%= notifications ? notifications.length : 0 %></strong></div>
        </div>
      </aside>

      <!-- Основная область -->
      <section class="mail-main">
        <div class="mail-toolbar">
          <div class="search-box">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" placeholder="Поиск по письмам...">
          </div>
          <button class="btn btn-sm btn-outline" id="refreshBtn">🔄 Обновить</button>
          <% if (unreadCount > 0) { %>
            <button class="btn btn-sm" id="markAllReadBtn">✅ Отметить все</button>
          <% } %>
        </div>

        <div class="mail-list-header">
          <span>Письма</span>
          <span class="count" id="visibleCount">0</span>
        </div>

        <div class="mail-list" id="mailList">
          <% if (notifications && notifications.length > 0) { %>
            <% notifications.forEach((n, index) => { %>
              <div class="mail-item <%= n.is_read ? 'read' : 'unread' %>" 
                   data-id="<%= n.id %>"
                   data-read="<%= n.is_read %>"
                   data-type="<%= getNotificationType(n.subject) %>"
                   style="animation-delay: <%= (index + 1) * 0.05 %>s">
                <div class="avatar"><%= getNotificationIcon(n.subject) %></div>
                <div class="content" onclick="openNotification(<%= n.id %>)">
                  <div class="subject">
                    <%= n.subject %>
                    <span class="badge-type <%= getNotificationType(n.subject) %>">
                      <%= getNotificationType(n.subject) === 'season' ? 'Сезон' : 
                         getNotificationType(n.subject) === 'balance' ? 'Начисление' : 'Системное' %>
                    </span>
                  </div>
                  <div class="body-preview">
                    <%= n.body.substring(0, 80) %><%= n.body.length > 80 ? '…' : '' %>
                  </div>
                  <div class="meta">
                    <span><%= new Date(n.created_at).toLocaleDateString() %> <%= new Date(n.created_at).toLocaleTimeString() %></span>
                    <% if (!n.is_read) { %>
                      <span class="unread-dot">● Новое</span>
                    <% } %>
                  </div>
                </div>
                <div class="actions">
                  <% if (!n.is_read) { %>
                    <button class="btn-read" onclick="markRead(<%= n.id %>)" title="Отметить прочитанным">✅</button>
                  <% } %>
                  <button class="btn-delete" onclick="deleteNotif(<%= n.id %>)" title="Удалить">🗑️</button>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="mail-empty" style="animation-delay: 0.4s">
              <div class="icon">📭</div>
              <h3>Почта пуста</h3>
              <p>Здесь будут появляться уведомления о начислениях, сезонах и важных событиях.</p>
            </div>
          <% } %>
        </div>
      </section>
    </div>

    <!-- Модалка просмотра -->
    <div class="modal-overlay" id="mailModal">
      <div class="modal-content mail-modal">
        <span class="modal-close" id="closeMailModal">&times;</span>
        <h2 id="modalSubject">Заголовок</h2>
        <div class="modal-meta">
          <span id="modalDate"></span>
          <span id="modalType" class="badge-type"></span>
        </div>
        <div class="modal-body" id="modalBody"></div>
        <div class="modal-actions">
          <button class="btn btn-sm" id="modalMarkRead" onclick="markRead(currentNotificationId)">✅ Отметить прочитанным</button>
          <button class="btn btn-sm btn-outline" id="modalDelete" onclick="deleteNotif(currentNotificationId)">🗑️ Удалить</button>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    let currentNotificationId = null;

    // === ПЕРЕКЛЮЧЕНИЕ ПАПОК И ФИЛЬТРОВ ===
    document.querySelectorAll('.folder-item, .filter-item').forEach(el => {
      el.addEventListener('click', function() {
        const parent = this.closest('.mail-card') || this.parentElement;
        parent.querySelectorAll('.folder-item, .filter-item').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        applyFilters();
      });
    });

    // === ПОИСК ===
    document.getElementById('searchInput').addEventListener('input', applyFilters);

    function applyFilters() {
      const folder = document.querySelector('.folder-item.active')?.dataset.filter || 'all';
      const filterType = document.querySelector('.filter-item.active')?.dataset.filterType || 'all';
      const query = document.getElementById('searchInput').value.toLowerCase();
      const items = document.querySelectorAll('.mail-item');
      let visible = 0;
      items.forEach(item => {
        const isRead = item.dataset.read === '1';
        const type = item.dataset.type || 'system';
        const text = item.textContent.toLowerCase();
        let show = true;
        if (folder === 'unread' && isRead) show = false;
        if (folder === 'read' && !isRead) show = false;
        if (filterType !== 'all' && type !== filterType) show = false;
        if (query && !text.includes(query)) show = false;
        item.style.display = show ? 'flex' : 'none';
        if (show) visible++;
      });
      document.getElementById('visibleCount').textContent = visible;
      document.getElementById('totalCount').textContent = document.querySelectorAll('.mail-item').length;
    }

    // === ОТКРЫТИЕ ПИСЬМА ===
    function openNotification(id) {
      const item = document.querySelector(`.mail-item[data-id="${id}"]`);
      if (!item) return;
      const subject = item.querySelector('.subject').textContent.trim();
      const bodyFull = item.querySelector('.body-preview').textContent.trim();
      const date = item.querySelector('.meta span')?.textContent.trim() || '';
      const type = item.dataset.type || 'system';
      const isRead = item.dataset.read === '1';

      document.getElementById('modalSubject').textContent = subject;
      document.getElementById('modalBody').textContent = bodyFull;
      document.getElementById('modalDate').textContent = date;
      const typeMap = { season: 'Сезон', balance: 'Начисление', system: 'Системное' };
      document.getElementById('modalType').textContent = typeMap[type] || 'Системное';
      document.getElementById('modalType').className = 'badge-type ' + type;

      document.getElementById('modalMarkRead').style.display = isRead ? 'none' : 'inline-block';
      currentNotificationId = id;
      document.getElementById('mailModal').style.display = 'flex';
    }

    // === ЗАКРЫТИЕ МОДАЛКИ ===
    document.getElementById('closeMailModal').addEventListener('click', () => {
      document.getElementById('mailModal').style.display = 'none';
    });
    window.addEventListener('click', (e) => {
      if (e.target === document.getElementById('mailModal')) {
        document.getElementById('mailModal').style.display = 'none';
      }
    });

    // === ОТМЕТИТЬ ПРОЧИТАННЫМ ===
    async function markRead(id) {
      if (!id) return;
      try {
        const res = await fetch(`/notifications/read/${id}`, { method: 'POST' });
        if (res.ok) {
          const item = document.querySelector(`.mail-item[data-id="${id}"]`);
          if (item) {
            item.classList.remove('unread');
            item.classList.add('read');
            item.dataset.read = '1';
            const dot = item.querySelector('.unread-dot');
            if (dot) dot.remove();
            updateUnreadBadge();
          }
          if (currentNotificationId === id) {
            document.getElementById('modalMarkRead').style.display = 'none';
          }
        } else {
          alert('Ошибка при отметке прочитанным');
        }
      } catch (e) {
        alert('Ошибка соединения');
      }
    }

    // === УДАЛЕНИЕ ===
    async function deleteNotif(id) {
      if (!id) return;
      if (!confirm('Удалить это уведомление?')) return;
      try {
        const res = await fetch(`/notifications/delete/${id}`, { method: 'POST' });
        if (res.ok) {
          const item = document.querySelector(`.mail-item[data-id="${id}"]`);
          if (item) item.remove();
          if (currentNotificationId === id) {
            document.getElementById('mailModal').style.display = 'none';
          }
          updateUnreadBadge();
          applyFilters();
        } else {
          alert('Ошибка при удалении');
        }
      } catch (e) {
        alert('Ошибка соединения');
      }
    }

    // === ОТМЕТИТЬ ВСЕ КАК ПРОЧИТАННЫЕ ===
    document.getElementById('markAllReadBtn')?.addEventListener('click', async function() {
      if (!confirm('Отметить все уведомления как прочитанные?')) return;
      try {
        const unreadItems = document.querySelectorAll('.mail-item.unread');
        for (const item of unreadItems) {
          const id = item.dataset.id;
          await fetch(`/notifications/read/${id}`, { method: 'POST' });
          item.classList.remove('unread');
          item.classList.add('read');
          item.dataset.read = '1';
          const dot = item.querySelector('.unread-dot');
          if (dot) dot.remove();
        }
        updateUnreadBadge();
        applyFilters();
        this.style.display = 'none';
        alert('Все уведомления отмечены как прочитанные!');
      } catch (e) {
        alert('Ошибка при отметке всех уведомлений');
      }
    });

    // === ОБНОВЛЕНИЕ БЕЙДЖА ===
    async function updateUnreadBadge() {
      try {
        const res = await fetch('/api/unread-count');
        const data = await res.json();
        const badge = document.querySelector('.folder-item[data-filter="unread"] .badge');
        if (badge) {
          badge.textContent = data.count || 0;
          badge.style.display = (data.count || 0) > 0 ? 'inline' : 'none';
        }
        // Показать/скрыть кнопку "Отметить все"
        const markAllBtn = document.getElementById('markAllReadBtn');
        if (markAllBtn) {
          markAllBtn.style.display = (data.count || 0) > 0 ? 'inline-block' : 'none';
        }
      } catch (e) {}
    }

    // === ОБНОВЛЕНИЕ СТРАНИЦЫ ===
    document.getElementById('refreshBtn').addEventListener('click', () => location.reload());

    // === ИНИЦИАЛИЗАЦИЯ ===
    document.addEventListener('DOMContentLoaded', () => {
      updateUnreadBadge();
      applyFilters();
    });

    // === ДЕЛАЕМ ФУНКЦИИ ГЛОБАЛЬНЫМИ ===
    window.openNotification = openNotification;
    window.markRead = markRead;
    window.deleteNotif = deleteNotif;
    window.currentNotificationId = currentNotificationId;
  </script>
</body>
</html>