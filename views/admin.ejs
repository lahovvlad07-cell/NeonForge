<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="admin-header fade-up" style="--delay:0.1">
      <h1 class="gradient-text">👑 Админ-панель</h1>
      <p class="text-secondary">Управление пользователями, сезонами, рекламой, ценами и уведомлениями</p>
    </div>

    <!-- Статистика -->
    <div class="stats-grid fade-up" style="--delay:0.2">
      <div class="stat-card">
        <span class="stat-icon">👥</span>
        <span class="stat-number"><%= stats.users || 0 %></span>
        <span class="stat-label">Пользователей</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">📅</span>
        <span class="stat-number"><%= stats.activeSeasons || 0 %></span>
        <span class="stat-label">Активных сезонов</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">📢</span>
        <span class="stat-number"><%= activeAds || 0 %></span>
        <span class="stat-label">Активных реклам</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">⏳</span>
        <span class="stat-number"><%= pendingAds || 0 %></span>
        <span class="stat-label">Заявок на модерации</span>
      </div>
    </div>

    <!-- Управление ценами -->
    <div class="admin-section fade-up" style="--delay:0.3">
      <div class="section-header">
        <h2>💲 Управление ценами</h2>
        <p>Установите стоимость рекламы за 1 день в каждом разделе.</p>
      </div>
      <a href="/admin/prices" class="btn">Перейти к ценам →</a>
    </div>

    <!-- Отправка уведомлений -->
    <div class="admin-section fade-up" style="--delay:0.35">
      <div class="section-header">
        <h2>📨 Уведомления</h2>
        <p>Отправьте системное сообщение всем пользователям или выбранному.</p>
      </div>
      <a href="/admin/send-notification" class="btn">Отправить уведомление →</a>
    </div>

    <!-- Сезоны -->
    <div class="admin-section fade-up" style="--delay:0.4">
      <div class="section-header">
        <h2>📅 Сезоны</h2>
        <button class="btn btn-sm" id="showSeasonForm">➕ Создать сезон</button>
      </div>

      <form action="/admin/season/create" method="POST" class="admin-form" id="seasonForm" style="display:none;">
        <div class="form-row">
          <div class="form-group">
            <input type="text" name="name" placeholder="Название сезона" required>
          </div>
          <div class="form-group">
            <input type="text" name="description" placeholder="Описание">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <input type="date" name="start_date" required>
          </div>
          <div class="form-group">
            <input type="date" name="end_date" required>
          </div>
        </div>
        <button type="submit" class="btn btn-sm">✅ Создать</button>
        <button type="button" class="btn btn-sm btn-outline" id="hideSeasonForm">Отмена</button>
      </form>

      <div class="table-wrapper">
        <table class="admin-table">
          <thead>
            <tr><th>ID</th><th>Название</th><th>Активен</th><th>Действия</th></tr>
          </thead>
          <tbody>
            <% seasons.forEach(season => { %>
              <tr>
                <td><%= season.id %></td>
                <td><%= season.name %></td>
                <td><%= season.is_active ? '✅ Да' : '❌ Нет' %></td>
                <td class="actions-cell">
                  <% if (!season.is_active) { %>
                    <form action="/admin/season/activate/<%= season.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm success">Активировать</button>
                    </form>
                  <% } %>
                  <% if (season.is_active) { %>
                    <form action="/admin/season/complete/<%= season.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm warning">Завершить</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Пользователи -->
    <div class="admin-section fade-up" style="--delay:0.5">
      <div class="section-header">
        <h2>👥 Пользователи</h2>
        <span class="badge-count"><%= users.length %></span>
      </div>
      <div class="table-wrapper">
        <table class="admin-table">
          <thead>
            <tr><th>ID</th><th>Username</th><th>Email</th><th>Баланс</th><th>Монеты</th><th>Рефералов</th></tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.id %></td>
                <td><strong><%= u.username %></strong></td>
                <td><%= u.email %></td>
                <td><%= u.balance || 0 %></td>
                <td><%= u.total_coins || 0 %></td>
                <td><%= u.referrer_id ? 'Есть' : 'Нет' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Рекламные заявки -->
    <div class="admin-section fade-up" style="--delay:0.6">
      <div class="section-header">
        <h2>📢 Рекламные заявки</h2>
        <a href="/admin-ads" class="btn btn-sm">Управлять заявками →</a>
      </div>
      <div class="table-wrapper">
        <table class="admin-table">
          <thead>
            <tr><th>ID</th><th>Проект</th><th>Статус</th><th>Бюджет</th></tr>
          </thead>
          <tbody>
            <% if (ads && ads.length > 0) { %>
              <% ads.slice(0, 5).forEach(ad => { %>
                <tr>
                  <td><%= ad.id %></td>
                  <td><%= ad.project_name %></td>
                  <td><span class="status-badge status-<%= ad.status %>"><%= ad.status %></span></td>
                  <td><%= ad.budget_tokens || '—' %></td>
                </tr>
              <% }) %>
              <% if (ads.length > 5) { %>
                <tr><td colspan="4" class="text-muted text-center">... и ещё <%= ads.length - 5 %> заявок</td></tr>
              <% } %>
            <% } else { %>
              <tr><td colspan="4" class="text-muted text-center">Нет заявок</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Показать/скрыть форму создания сезона
    document.getElementById('showSeasonForm').addEventListener('click', function() {
      document.getElementById('seasonForm').style.display = 'flex';
      this.style.display = 'none';
    });
    document.getElementById('hideSeasonForm').addEventListener('click', function() {
      document.getElementById('seasonForm').style.display = 'none';
      document.getElementById('showSeasonForm').style.display = 'inline-block';
    });
  </script>
</body>
</html>