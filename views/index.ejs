<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <!-- Баннер -->
    <div class="ad-slot ad-slot-top fade-up" style="--delay:0.1">
      <% if (activeBanners && activeBanners.length > 0) { %>
        <a href="<%= activeBanners[0].link || '#' %>" target="_blank" class="ad-banner">
          <img src="<%= activeBanners[0].banner %>" alt="<%= activeBanners[0].project_name %>">
          <span class="ad-label">Реклама</span>
        </a>
      <% } else { %>
        <div class="ad-placeholder">
          <span class="placeholder-icon">📢</span>
          <span class="placeholder-text">Рекламное место</span>
          <a href="/ad-buy" class="btn btn-sm btn-placeholder">Разместить</a>
        </div>
      <% } %>
    </div>

    <!-- HERO -->
    <section class="hero fade-up" style="--delay:0.2">
      <h1 class="gradient-text">
        Добро пожаловать в <span class="logo-text">Neon</span><span class="logo-accent">Forge</span>
      </h1>
      <p class="subtitle">Экосистема мини-игр с собственной валютой. Играй, зарабатывай, выводи.</p>
      <a href="/register" class="btn btn-hero">🚀 Начать</a>
    </section>

    <!-- СТАТИСТИКА -->
    <div class="stats-grid fade-up" style="--delay:0.4">
      <div class="stat-card">
        <span class="stat-icon">👥</span>
        <span class="stat-number" id="statUsers" data-target="<%= stats.users || 0 %>">0</span>
        <span class="stat-label">Пользователей</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🟢</span>
        <span class="stat-number" id="statOnline" data-target="<%= stats.online || 0 %>">0</span>
        <span class="stat-label">Сейчас онлайн</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">✅</span>
        <span class="stat-number" id="statSeasons" data-target="<%= stats.completedSeasons || 0 %>">0</span>
        <span class="stat-label">Завершённых сезонов</span>
      </div>
    </div>

    <!-- 6 КАРТОЧЕК -->
    <div class="features-grid">
      <div class="feature-card fade-up" style="--delay:0.6; --card-color: var(--accent-blue);">
        <span class="icon">🎮</span>
        <h3>Мини-игры</h3>
        <p>Зарабатывай монеты, проходя увлекательные испытания.</p>
        <span class="card-badge">Играй</span>
      </div>

      <div class="feature-card fade-up" style="--delay:0.7; --card-color: var(--accent-purple);">
        <span class="icon">📈</span>
        <h3>Вывод частями</h3>
        <p>Получай токены по 10% в месяц — долгосрочная выгода.</p>
        <span class="card-badge">10% в месяц</span>
      </div>

      <div class="feature-card fade-up" style="--delay:0.8; --card-color: var(--accent-green);">
        <span class="icon">📢</span>
        <h3>Рекламная биржа</h3>
        <p>Размещай рекламу и привлекай аудиторию.</p>
        <span class="card-badge">Популярно</span>
      </div>

      <div class="feature-card fade-up" style="--delay:0.9; --card-color: var(--accent-gold);">
        <span class="icon">🔄</span>
        <h3>Конвертация</h3>
        <p>Монеты автоматически превращаются в токены в конце сезона.</p>
        <span class="card-badge">Автоматически</span>
      </div>

      <div class="feature-card fade-up" style="--delay:1.0; --card-color: #f472b6;">
        <span class="icon">💬</span>
        <h3>Поддержка</h3>
        <p>Всегда на связи, помогаем с любыми вопросами.</p>
        <span class="card-badge">24/7</span>
      </div>

      <div class="feature-card fade-up" style="--delay:1.1; --card-color: #f97316;">
        <span class="icon">🏆</span>
        <h3>Еженедельные турниры</h3>
        <p>Соревнуйтесь с другими игроками и выигрывайте бонусы.</p>
        <span class="card-badge">Скоро</span>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    <% if (user) { %>
      setInterval(() => {
        socket.emit('ping', <%= user.id %>);
      }, 15000);
    <% } %>

    // === Анимированный счётчик ===
    document.addEventListener('DOMContentLoaded', function() {
      const counters = document.querySelectorAll('.stat-number');
      counters.forEach(counter => {
        const target = parseInt(counter.dataset.target);
        const duration = 1500;
        const startTime = performance.now();
        function updateCounter(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const current = Math.floor(progress * target);
          counter.textContent = current;
          if (progress < 1) {
            requestAnimationFrame(updateCounter);
          } else {
            counter.textContent = target;
          }
        }
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              requestAnimationFrame(updateCounter);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        observer.observe(counter);
      });
    });

    // === Обновление онлайн-статуса ===
    socket.on('online_update', (data) => {
      const onlineEl = document.getElementById('statOnline');
      if (onlineEl) {
        onlineEl.textContent = data.online;
        onlineEl.dataset.target = data.online;
      }
    });

    // === Периодическое обновление статистики ===
    setInterval(async () => {
      try {
        const res = await fetch('/api/stats');
        const stats = await res.json();
        document.getElementById('statUsers').textContent = stats.users;
        document.getElementById('statUsers').dataset.target = stats.users;
        document.getElementById('statOnline').textContent = stats.online;
        document.getElementById('statOnline').dataset.target = stats.online;
        document.getElementById('statSeasons').textContent = stats.completedSeasons;
        document.getElementById('statSeasons').dataset.target = stats.completedSeasons;
      } catch (e) {}
    }, 30000);
  </script>
</body>
</html>