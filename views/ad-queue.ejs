<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/ad-queue.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <!-- Баннер -->
    <div class="ad-slot ad-slot-top fade-up" style="--delay:0.1">
      <% if (activeBanners && activeBanners.length > 0) { %>
        <a href="<%= activeBanners[0].link || '#' %>" target="_blank" class="ad-banner">
          <img src="<%= activeBanners[0].banner %>" alt="<%= activeBanners[0].project_name %>">
          <span class="ad-label">Реклама</span>
        </a>
      <% } else { %>
        <div class="ad-placeholder">
          <span class="placeholder-icon">📢</span>
          <span class="placeholder-text">Рекламное место</span>
          <a href="/ad-buy" class="btn btn-sm btn-placeholder">Разместить</a>
        </div>
      <% } %>
    </div>

    <section class="ad-hero fade-up" style="--delay:0.2">
      <h1 class="gradient-text">Рекламная биржа</h1>
      <p class="subtitle">Активные рекламные кампании и заявки на рассмотрении</p>
    </section>

    <!-- Блок баланса -->
    <% if (user) { %>
      <div class="ad-balance-block fade-up" style="--delay:0.3">
        <div class="balance-info">
          <span class="balance-label">💰 Рекламный баланс</span>
          <span class="balance-value"><%= user.balance || 0 %></span>
          <span class="balance-hint">≈ $<%= ((user.balance || 0) * 0.01).toFixed(2) %></span>
        </div>
        <button class="btn btn-primary" id="openTopupModal">Пополнить</button>
      </div>

      <!-- Модалка пополнения -->
      <div class="modal-overlay" id="topupModal">
        <div class="modal-content">
          <span class="modal-close" id="closeModal">&times;</span>
          <h2>Пополнение баланса</h2>
          <p class="modal-hint">Выберите способ пополнения</p>
          <div class="modal-tabs">
            <button class="modal-tab active" data-tab="stars">⭐ Telegram Stars</button>
            <button class="modal-tab" data-tab="crypto">🪙 Криптовалюта</button>
          </div>
          <div id="tab-stars" class="modal-tab-content active">
            <p class="tab-hint">1 ⭐ = 1 токен. Минимальная сумма — 10 ⭐.</p>
            <div class="modal-presets">
              <button class="preset-btn" data-amount="10">10 ⭐</button>
              <button class="preset-btn" data-amount="50">50 ⭐</button>
              <button class="preset-btn" data-amount="100">100 ⭐</button>
              <button class="preset-btn" data-amount="200">200 ⭐</button>
              <button class="preset-btn" data-amount="500">500 ⭐</button>
            </div>
            <div class="modal-custom">
              <input type="number" id="modalCustomAmount" min="10" step="1" placeholder="Своя сумма (минимум 10 ⭐)">
              <button class="btn" id="modalTopupBtn">Пополнить</button>
            </div>
            <div id="modalMessage" class="message" style="display:none;"></div>
          </div>
          <div id="tab-crypto" class="modal-tab-content">
            <p class="tab-hint">Поддерживаются BTC, USDT, TON, ETH. Минимальная сумма — $10.</p>
            <div class="crypto-list">
              <div class="crypto-item"><span class="crypto-icon">₿</span><span class="crypto-name">Bitcoin (BTC)</span><span class="crypto-status">Скоро</span></div>
              <div class="crypto-item"><span class="crypto-icon">$</span><span class="crypto-name">USDT (ERC-20)</span><span class="crypto-status">Скоро</span></div>
              <div class="crypto-item"><span class="crypto-icon">⧫</span><span class="crypto-name">TON</span><span class="crypto-status">Скоро</span></div>
              <div class="crypto-item"><span class="crypto-icon">⟠</span><span class="crypto-name">Ethereum (ETH)</span><span class="crypto-status">Скоро</span></div>
            </div>
            <button class="btn btn-outline" disabled style="width:100%;">В разработке</button>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="ad-balance-block fade-up" style="--delay:0.3">
        <div class="balance-info">
          <span class="balance-label">💰 Рекламный баланс</span>
          <span class="balance-value">—</span>
          <span class="balance-hint">Войдите, чтобы пополнять</span>
        </div>
        <a href="/login" class="btn btn-primary">Войти</a>
      </div>
    <% } %>

    <!-- Активная реклама -->
    <section class="ad-section fade-up" style="--delay:0.4">
      <h2>✅ Активная реклама</h2>
      <div class="ad-grid">
        <% if (activeAds && activeAds.length > 0) { %>
          <% activeAds.forEach(ad => { %>
            <div class="ad-card active" data-expires="<%= ad.remaining_seconds %>">
              <div class="ad-header">
                <span class="ad-project"><%= ad.project_name %></span>
                <span class="ad-pos">#<%= ad.queue_position %></span>
              </div>
              <p class="ad-desc"><%= ad.description || 'Без описания' %></p>
              <% if (ad.link) { %>
                <a href="<%= ad.link %>" target="_blank" class="ad-link">Перейти →</a>
              <% } %>
              <div class="ad-meta">
                <span>💵 <%= ad.budget_tokens || '—' %> токенов</span>
                <span>⏱️ <%= ad.duration_days || '—' %> дней</span>
                <span>📌 <%= ad.placement || '—' %></span>
              </div>
              <div class="ad-timer">
                <% if (ad.not_started) { %>
                  <span class="waiting-badge">⏳ Ожидает очереди</span>
                <% } else { %>
                  <span>⏳ Осталось: </span>
                  <span class="timer-display" data-seconds="<%= ad.remaining_seconds %>">
                    <% if (ad.is_expired) { %>
                      ✅ Завершена
                    <% } else { %>
                      <%= ad.remaining_days %>д <%= ad.remaining_hours %>ч <%= ad.remaining_minutes %>м <%= ad.remaining_seconds_short %>с
                    <% } %>
                  </span>
                  <% if (ad.is_expired) { %>
                    <span class="expired-badge">✅ Завершена</span>
                  <% } %>
                <% } %>
              </div>
              <div class="ad-progress">
                <div class="progress-bar" style="width: <%= (1 - (ad.remaining_seconds / (ad.duration_days * 86400))) * 100 %>%"></div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state">
            <span class="empty-icon">📭</span>
            <h3>Нет активной рекламы</h3>
            <p>Подайте заявку, чтобы попасть в очередь.</p>
            <a href="/ad-buy" class="btn btn-sm">Подать заявку</a>
          </div>
        <% } %>
      </div>

      <!-- Пагинация -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="page-link">&larr; Назад</a>
          <% } %>

          <% 
            const pages = [];
            const total = totalPages;
            const current = currentPage;
            const delta = 2;
            for (let i = 1; i <= total; i++) {
              if (
                i === 1 ||
                i === total ||
                (i >= current - delta && i <= current + delta)
              ) {
                pages.push(i);
              } else if (pages[pages.length - 1] !== '...') {
                pages.push('...');
              }
            }
          %>

          <% pages.forEach(function(p) { %>
            <% if (p === '...') { %>
              <span class="page-dots">…</span>
            <% } else { %>
              <a href="?page=<%= p %>" class="page-link <%= p === current ? 'active' : '' %>"><%= p %></a>
            <% } %>
          <% }) %>

          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="page-link">Вперёд &rarr;</a>
          <% } %>
        </div>
      <% } %>
    </section>

    <!-- Ожидают одобрения -->
    <section class="ad-section fade-up" style="--delay:0.5">
      <h2>⏳ Ожидают одобрения</h2>
      <% if (pendingAds && pendingAds.length > 0) { %>
        <div class="ad-grid">
          <% pendingAds.forEach(ad => { %>
            <div class="ad-card pending">
              <div class="ad-header">
                <span class="ad-project"><%= ad.project_name %></span>
                <span class="ad-status pending">На рассмотрении</span>
              </div>
              <p class="ad-desc"><%= ad.description || 'Без описания' %></p>
              <div class="ad-meta">
                <span>💵 <%= ad.budget_tokens || '—' %> токенов</span>
                <span>📅 <%= new Date(ad.created_at).toLocaleDateString() %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <span class="empty-icon">📪</span>
          <h3>Нет заявок на рассмотрении</h3>
          <p>Все заявки обработаны или ещё не поданы.</p>
          <a href="/ad-buy" class="btn btn-sm">Подать заявку</a>
        </div>
      <% } %>
    </section>

    <!-- Кнопка подачи заявки -->
    <div class="ad-actions fade-up" style="--delay:0.6">
      <a href="/ad-buy" class="btn">Подать заявку на рекламу</a>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    <% if (user) { %>
      setInterval(() => {
        socket.emit('ping', <%= user.id %>);
      }, 15000);
    <% } %>

    // Модалка
    const modal = document.getElementById('topupModal');
    const openBtn = document.getElementById('openTopupModal');
    const closeBtn = document.getElementById('closeModal');

    if (openBtn) {
      openBtn.addEventListener('click', () => modal.style.display = 'flex');
      closeBtn.addEventListener('click', () => modal.style.display = 'none');
      window.addEventListener('click', (e) => {
        if (e.target === modal) modal.style.display = 'none';
      });
    }

    // Вкладки в модалке
    document.querySelectorAll('.modal-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        const tabId = this.dataset.tab;
        document.querySelectorAll('.modal-tab-content').forEach(tc => tc.classList.remove('active'));
        document.getElementById('tab-' + tabId).classList.add('active');
      });
    });

    // Прессеты
    document.querySelectorAll('#tab-stars .preset-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.getElementById('modalCustomAmount').value = this.dataset.amount;
      });
    });

    // Пополнение
    document.getElementById('modalTopupBtn').addEventListener('click', async function() {
      const input = document.getElementById('modalCustomAmount');
      const amount = parseInt(input.value);
      const msg = document.getElementById('modalMessage');

      if (!amount || amount < 10) {
        msg.style.display = 'block';
        msg.className = 'message error';
        msg.textContent = 'Минимальная сумма – 10 ⭐';
        return;
      }

      try {
        const res = await fetch('/topup-tokens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ stars_amount: amount })
        });
        const data = await res.json();
        if (data.success) {
          msg.style.display = 'block';
          msg.className = 'message success';
          msg.textContent = `✅ Пополнено на ${data.tokens} токенов!`;
          const balanceVal = document.querySelector('.balance-value');
          const current = parseFloat(balanceVal.textContent.replace(/,/g, ''));
          balanceVal.textContent = (current + data.tokens).toFixed(0);
          const hint = document.querySelector('.balance-hint');
          const newBalance = current + data.tokens;
          hint.textContent = `≈ $${(newBalance * 0.01).toFixed(2)}`;
          input.value = '';
          setTimeout(() => {
            modal.style.display = 'none';
            location.reload();
          }, 1500);
        } else {
          msg.style.display = 'block';
          msg.className = 'message error';
          msg.textContent = '❌ ' + (data.error || 'Ошибка пополнения');
        }
      } catch (e) {
        msg.style.display = 'block';
        msg.className = 'message error';
        msg.textContent = '❌ Ошибка соединения с сервером';
      }
    });

    // Обновление таймеров
    function updateTimers() {
      const timers = document.querySelectorAll('.timer-display');
      timers.forEach(el => {
        let seconds = parseInt(el.dataset.seconds);
        if (isNaN(seconds) || seconds <= 0) return;
        seconds--;
        el.dataset.seconds = seconds;
        const days = Math.floor(seconds / 86400);
        const hours = Math.floor((seconds % 86400) / 3600);
        const minutes = Math.floor((seconds % 3600) / 60);
        const secs = seconds % 60;
        el.textContent = `${days}д ${hours}ч ${minutes}м ${secs}с`;
        // Обновляем прогресс-бар
        const progressBar = el.closest('.ad-card').querySelector('.progress-bar');
        if (progressBar) {
          const totalSeconds = parseInt(el.closest('.ad-card').dataset.expires);
          const remaining = parseInt(el.dataset.seconds);
          const progress = (1 - (remaining / totalSeconds)) * 100;
          progressBar.style.width = Math.min(progress, 100) + '%';
        }
      });
    }

    setInterval(updateTimers, 1000);
  </script>
</body>
</html>